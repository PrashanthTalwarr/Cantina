# ============================================================================
# Cantina Discovery Pipeline — Environment Variables
# Copy this to .env and fill in your values
# IMPORTANT: no spaces around = signs, no quotes around values
# ============================================================================

# --- Database (optional — pipeline runs without it) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cantina_pipeline

# --- Anthropic (Claude API for LLM-powered outreach generation) ---
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxx
# Optional: override model (default: claude-sonnet-4-20250514)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- GitHub (optional — increases rate limit from 60 to 5000 req/hr) ---
# Get from: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_xxxxxxxx

# --- Enrichment APIs ---
# DeFiLlama base URL (no key needed, free)
DEFILLAMA_BASE_URL=https://api.llama.fi

# --- Integrations ---
# HubSpot: create a Private App at app.hubspot.com → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.contacts.read
HUBSPOT_API_KEY=
# Slack: create an Incoming Webhook at api.slack.com → Your Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
# Resend: get your API key at resend.com → API Keys
RESEND_API_KEY=
# Verified sender address from your Resend domain
RESEND_FROM_EMAIL=outreach@cantina.xyz
RESEND_TEST_EMAIL=yourgmail@gmail.com

# --- Pipeline Config ---
# These are read from config/scoring_weights.json at runtime
# Set here only if you want to override the JSON config values
# SCORING_CONFIG_PATH=config/scoring_weights.json
